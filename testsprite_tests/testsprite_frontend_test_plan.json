[
  {
    "id": "TC001",
    "title": "Successful registration redirects to dashboard",
    "description": "Verifies a user can create an account with valid details, accept terms, and is redirected to the dashboard.",
    "category": "User Registration",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /register"
      },
      {
        "type": "action",
        "description": "Type \"newuser_qa_01\" into the Username field"
      },
      {
        "type": "action",
        "description": "Type \"newuser_qa_01@example.com\" into the Email field"
      },
      {
        "type": "action",
        "description": "Type \"Str0ngPass!234\" into the Password field"
      },
      {
        "type": "assertion",
        "description": "Verify element \"Password strength indicator\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"Str0ngPass!234\" into the Confirm Password field"
      },
      {
        "type": "action",
        "description": "Click on the Terms and Conditions checkbox"
      },
      {
        "type": "action",
        "description": "Click on the \"Create Account\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Projects\" is visible"
      }
    ]
  },
