  {
    "id": "TC014",
    "title": "Create project via wizard and land in workspace",
    "description": "Verifies a user can complete all wizard steps and is redirected to the workspace after creating a project.",
    "category": "Create Project Wizard",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Sign in\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "action",
        "description": "Click the \"New Project\" or \"Create Project\" call-to-action"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/projects/new\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Project Information\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"E2E Wizard Project\" into the project name field"
      },
      {
        "type": "action",
        "description": "Type \"Project created by end-to-end test\" into the project description field"
      },
      {
        "type": "action",
        "description": "Click the \"Proceed\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Type\" is visible"
      },
      {
        "type": "action",
        "description": "Select \"Web\" from the project type options"
      },
      {
        "type": "action",
        "description": "Click the \"Proceed\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Configuration\" is visible"
      },
      {
        "type": "action",
        "description": "Select \"IntelliJ\" from the software dropdown"
      },
      {
        "type": "action",
        "description": "Select \"Java\" from the language dropdown"
      },
      {
        "type": "action",
        "description": "Select \"17\" from the Java version dropdown"
      },
      {
        "type": "action",
        "description": "Select \"Maven\" from the compiler dropdown"
      },
      {
        "type": "action",
        "description": "Click the \"Proceed\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Source\" is visible"
      },
      {
        "type": "action",
        "description": "Select \"Starter Template\" from the source template options"
      },
      {
        "type": "action",
        "description": "Click the \"Create Project\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/workspace/\""
      },
      {
        "type": "assertion",
        "description": "Verify element \"Workspace\" is visible"
      }
    ]
  },
